# Telegram client API credentials from https://my.telegram.org/apps
# Sign in with your Telegram phone number, create an app, then copy:
#   App api_id   -> TELEGRAM_API_ID
#   App api_hash -> TELEGRAM_API_HASH
# These identify the app session. Keep them private. Vamos authenticates as a
# user account (not a Bot API token) so it can upload files up to 2 GB free /
# 4 GB Premium, which the Bot API does not allow.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional override for the vault target. The vault config created by
# `vamos-vault init` also stores a target, so this is rarely needed.
# Use one of: me, @channel_username, private invite link, or numeric chat ID.
TELEGRAM_TARGET=me

# Optional override for the SQLite database path.
VAMOS_VAULT_DB=.vamos-vault/vault.db
